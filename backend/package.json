{
  "name": "healthhub-backend",
  "version": "1.0.0",
  "description": "HealthHub Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/database/schema.sql','dist/database/schema.sql')\"",
    "start": "node dist/index.js",
    "db:migrate": "ts-node src/database/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "pg": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^6.3.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
